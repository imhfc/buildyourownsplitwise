DATABASE_URL=postgresql+asyncpg://splitewise:splitewise@localhost:5432/splitewise
SECRET_KEY=change-me-in-production-use-a-real-secret-key
REDIS_URL=redis://localhost:6379/0
DEBUG=true
# Google OAuth - Web client ID from Google Cloud Console
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com
# CORS - 逗號分隔允許來源，生產環境應設為實際網域
# 範例: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# 開發預設為 * (全部允許)
ALLOWED_ORIGINS=*
