		{
			"name": "2. HTG 手動登入",
			"item": [
				{
					"name": "HTG-登入-NVNSC-SIT",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// ========== SIT 手動登入 v6 ==========",
									"var responseBody = pm.response.text();",
									"var sessionIdMatch = responseBody.match(/<data id=\"sessionId\" value=\"([^\"]+)\"\\/>/);",
									"",
									"if (sessionIdMatch && sessionIdMatch[1]) {",
									"    pm.globals.set('sit-htg-session-id', sessionIdMatch[1]);",
									"    pm.globals.set('lastSessionTime', Date.now());",
									"    console.log('[SIT] Session ID:', sessionIdMatch[1]);",
									"} else {",
									"    console.log('[SIT] 無法解析 sessionId');",
									"    console.log('[SIT] Response:', responseBody.substring(0, 500));",
									"}",
									"",
									"// ========== 提取 ARPT v6 ==========",
									"var arptValue = null;",
									"var htgDomain = '192.168.38.136';",
									"var htgUrl = 'http://' + htgDomain + '/WS_HG/HgXmlRequestHandler';",
									"",
									"console.log('[SIT] === 開始提取 ARPT ===');",
									"",
									"// 方式 1: 從 Response Headers",
									"var headers = pm.response.headers;",
									"if (headers && typeof headers.all === 'function') {",
									"    var allHeaders = headers.all();",
									"    for (var i = 0; i < allHeaders.length; i++) {",
									"        var h = allHeaders[i];",
									"        var hKey = h.key || h.name || '';",
									"        var hVal = h.value || '';",
									"        if (hKey.toLowerCase() === 'set-cookie' && hVal.indexOf('ARPT=') !== -1) {",
									"            var m = hVal.match(/ARPT=([^;]+)/);",
									"            if (m && m[1]) {",
									"                arptValue = m[1];",
									"                console.log('[SIT] 從 Response Headers 找到 ARPT:', arptValue);",
									"            }",
									"        }",
									"    }",
									"}",
									"",
									"// 方式 2: 從 Cookie Jar",
									"var cookieJar = pm.cookies.jar();",
									"cookieJar.getAll(htgUrl, function(err, cookies) {",
									"    if (!err && cookies && cookies.length > 0) {",
									"        for (var j = 0; j < cookies.length; j++) {",
									"            var c = cookies[j];",
									"            var cName = (c.name || c.key || '').toUpperCase();",
									"            if (cName === 'ARPT') {",
									"                if (!arptValue) {",
									"                    arptValue = c.value;",
									"                    pm.globals.set('sit-htg-arpt', 'ARPT=' + arptValue);",
									"                    console.log('[SIT] 從 Cookie Jar 找到 ARPT:', arptValue);",
									"                }",
									"            }",
									"        }",
									"    }",
									"});",
									"",
									"// 方式 3: 從 Request Cookie header",
									"if (!arptValue) {",
									"    var reqCookie = pm.request.headers.get('Cookie');",
									"    if (reqCookie) {",
									"        var m2 = reqCookie.match(/ARPT=([^;]+)/);",
									"        if (m2 && m2[1]) {",
									"            arptValue = m2[1];",
									"            console.log('[SIT] 從 Request Cookie 找到 ARPT:', arptValue);",
									"        }",
									"    }",
									"}",
									"",
									"console.log('[SIT] === 結束提取 ARPT ===');",
									"",
									"if (arptValue) {",
									"    pm.globals.set('sit-htg-arpt', 'ARPT=' + arptValue);",
									"    console.log('[SIT] ARPT 已儲存');",
									"} else {",
									"    console.log('[SIT] 未找到 ARPT - 請先執行「取得 ARPT (SIT)」請求');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/xml",
								"type": "default"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<hostgateway>\n    <header>\n        <action type=\"P8EstablishSession\"/>\n    </header>\n    <body>\n        <data id=\"userId\" value=\"{{HTG_LDAP_USER}}\"/>\n        <data id=\"passWord\" value=\"{{HTG_LDAP_PASSWORD}}\"/>\n        <data id=\"branchNo\" value=\"{{HTG_SIT_BRANCH_NO}}\"/>\n        <data id=\"racfId\" value=\"{{HTG_SIT_RACF_ID}}\"/>\n        <data id=\"racfPassWord\" value=\"{{HTG_SIT_RACF_PASSWORD}}\"/>\n        <data id=\"signOnLU0\" value=\"no0\"/>\n        <data id=\"applicationId\" value=\"{{HTG_APP_ID}}\"/>\n    </body>\n</hostgateway>",
							"options": {
								"raw": {
									"language": "xml"
								}
							}
						},
						"url": {
							"raw": "http://192.168.38.136:80/WS_HG/HgXmlRequestHandler",
							"protocol": "http",
							"host": [
								"192",
								"168",
								"38",
								"136"
							],
							"port": "80",
							"path": [
								"WS_HG",
								"HgXmlRequestHandler"
							]
						},
						"description": "手動登入 HTG SIT"
					},
					"response": []
				},
				{
