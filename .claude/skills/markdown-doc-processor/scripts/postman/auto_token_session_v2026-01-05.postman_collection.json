				{
					"name": "檢視目前狀態",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// ========================================",
									"// 顯示目前所有認證變數狀態",
									"// ========================================",
									"",
									"console.log('╔════════════════════════════════════════════════════════════════╗');",
									"console.log('║                      目前認證狀態                              ║');",
									"console.log('╚════════════════════════════════════════════════════════════════╝');",
									"",
									"// Token 狀態",
									"var token = pm.globals.get('x-authorization-ap');",
									"var lastTokenTime = pm.globals.get('lastTokenTime');",
									"var tokenExpiry = lastTokenTime ? new Date(lastTokenTime + 3*60*60*1000) : null;",
									"",
									"console.log('');",
									"console.log('📌 JWT Token:');",
									"console.log('   狀態:', token ? '已取得' : '未取得');",
									"if (tokenExpiry) {",
									"    var isExpired = Date.now() > tokenExpiry.getTime();",
									"    console.log('   過期時間:', tokenExpiry.toLocaleString());",
									"    console.log('   目前狀態:', isExpired ? '已過期' : '有效');",
									"}",
									"",
									"// Session 狀態",
									"var sessionSit = pm.globals.get('sit-htg-session-id');",
									"var sessionUat = pm.globals.get('uat-htg-session-id');",
									"var lastSessionTime = pm.globals.get('lastSessionTime');",
									"var sessionExpiry = lastSessionTime ? new Date(lastSessionTime + 1*60*60*1000) : null;",
									"",
									"console.log('');",
									"console.log('📌 HTG Session (SIT):');",
									"console.log('   Session ID:', sessionSit || '未取得');",
									"console.log('   ARPT:', pm.globals.get('sit-htg-arpt') || '未取得');",
									"",
									"console.log('');",
									"console.log('📌 HTG Session (UAT):');",
									"console.log('   Session ID:', sessionUat || '未取得');",
									"console.log('   ARPT:', pm.globals.get('uat-htg-arpt') || '未取得');",
									"",
									"if (sessionExpiry) {",
									"    var isSessionExpired = Date.now() > sessionExpiry.getTime();",
									"    console.log('');",
									"    console.log('📌 Session 過期狀態:');",
									"    console.log('   過期時間:', sessionExpiry.toLocaleString());",
									"    console.log('   目前狀態:', isSessionExpired ? '已過期' : '有效');",
									"}",
									"",
									"console.log('');",
									"console.log('════════════════════════════════════════════════════════════════');",
									"",
									"// 阻止實際請求發送",
									"throw new Error('僅顯示狀態，不發送請求');"
								],
								"type": "text/javascript"
							}
						}
					],
