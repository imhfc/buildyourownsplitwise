						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// 此請求會觸發 Collection Pre-request Script 取得 Token & Session",
									"console.log('');",
									"console.log('╔════════════════════════════════════════════════════════════════╗');",
									"console.log('║              初始化 Token & Session                         ║');",
									"console.log('╚════════════════════════════════════════════════════════════════╝');",
									"console.log('');",
									"console.log('正在取得 Token 和 Session...');",
									"console.log('(Collection Pre-request Script 會自動執行)');",
									"console.log('');",
									"console.log('第一次執行可能會出現 token 錯誤，這是正常的！');",
									"console.log('請再執行一次，Token 就會生效。');",
									"console.log('');",
									"console.log('如果 ARPT 未取得，請先執行「取得 ARPT (SIT/UAT)」請求一次。');"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// 檢查初始化結果",
									"console.log('');",
									"console.log('════════════════════════════════════════════════════════════════');",
									"console.log('📌 Token:', pm.globals.get('x-authorization-ap') ? '已取得' : '未取得');",
									"console.log('📌 SIT Session:', pm.globals.get('sit-htg-session-id') || '⏳ 請再執行一次');",
									"console.log('📌 UAT Session:', pm.globals.get('uat-htg-session-id') || '⏳ 請再執行一次');",
									"console.log('📌 SIT ARPT:', pm.globals.get('sit-htg-arpt') || '請執行「取得 ARPT (SIT)」');",
									"console.log('📌 UAT ARPT:', pm.globals.get('uat-htg-arpt') || '請執行「取得 ARPT (UAT)」');",
									"console.log('════════════════════════════════════════════════════════════════');",
									"",
									"if (pm.globals.get('x-authorization-ap')) {",
									"    console.log('');",
									"    console.log('初始化完成！現在可以執行其他 API 請求了。');",
									"    if (!pm.globals.get('sit-htg-arpt') && !pm.globals.get('uat-htg-arpt')) {",
									"        console.log('');",
									"        console.log('ARPT 尚未取得，建議執行「取得 ARPT」請求。');",
									"    }",
									"} else {",
									"    console.log('');",
									"    console.log('Token 尚未取得，請再執行一次此請求。');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
