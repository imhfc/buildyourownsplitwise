								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/xml",
								"type": "default"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<hostgateway>\n    <header>\n        <action type=\"P8EstablishSession\"/>\n    </header>\n    <body>\n        <data id=\"userId\" value=\"{{HTG_LDAP_USER}}\"/>\n        <data id=\"passWord\" value=\"{{HTG_LDAP_PASSWORD}}\"/>\n        <data id=\"branchNo\" value=\"{{HTG_UAT_BRANCH_NO}}\"/>\n        <data id=\"racfId\" value=\"{{HTG_UAT_RACF_ID}}\"/>\n        <data id=\"racfPassWord\" value=\"{{HTG_UAT_RACF_PASSWORD}}\"/>\n        <data id=\"signOnLU0\" value=\"no0\"/>\n        <data id=\"applicationId\" value=\"{{HTG_APP_ID}}\"/>\n    </body>\n</hostgateway>",
							"options": {
