							}
						},
						"url": {
							"raw": "{{HTG_UAT_ENDPOINT}}",
							"host": [
								"{{HTG_UAT_ENDPOINT}}"
							]
						},
						"description": "手動登入 HTG UAT"
					},
					"response": []
				}
			],
			"description": "HTG 手動登入（一般不需要使用）"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// ╔════════════════════════════════════════════════════════════════════════╗",
					"// ║              自動取得 Token & Session 腳本 (全自動版)                   ║",
					"// ║                   版本號：2026-01-05 v8 (Cookie Jar Fallback)          ║",
					"// ║                   支援 Postman 10.x                                    ║",
					"// ╚════════════════════════════════════════════════════════════════════════╝",
					"",
					"// ┌────────────────────────────────────────────────────────────────────────┐",
					"// │ 1. 配置驗證 - 檢查必要變數                                             │",
					"// └────────────────────────────────────────────────────────────────────────┘",
					"",
					"var REQUIRED_VARS = [",
					"    { key: 'HTG_LDAP_USER', desc: 'LDAP 使用者 ID' },",
					"    { key: 'HTG_LDAP_PASSWORD', desc: 'LDAP 密碼' },",
					"    { key: 'HTG_APP_ID', desc: '應用程式 ID' },",
					"    { key: 'HTG_SIT_ENDPOINT', desc: 'SIT HTG 端點' },",
					"    { key: 'HTG_SIT_RACF_ID', desc: 'SIT RACF ID' },",
					"    { key: 'HTG_SIT_RACF_PASSWORD', desc: 'SIT RACF 密碼' },",
					"    { key: 'HTG_SIT_BRANCH_NO', desc: 'SIT 分行代碼' },",
					"    { key: 'HTG_UAT_ENDPOINT', desc: 'UAT HTG 端點' },",
					"    { key: 'HTG_UAT_RACF_ID', desc: 'UAT RACF ID' },",
					"    { key: 'HTG_UAT_RACF_PASSWORD', desc: 'UAT RACF 密碼' },",
					"    { key: 'HTG_UAT_BRANCH_NO', desc: 'UAT 分行代碼' },",
					"    { key: 'TOKEN_ENDPOINT', desc: 'JWT Token 端點' },",
					"    { key: 'TOKEN_EXPIRY_HOURS', desc: 'Token 有效時間(小時)' },",
					"    { key: 'SESSION_EXPIRY_HOURS', desc: 'Session 有效時間(小時)' }",
					"];",
					"",
					"var missingVars = [];",
					"for (var i = 0; i < REQUIRED_VARS.length; i++) {",
					"    var value = pm.collectionVariables.get(REQUIRED_VARS[i].key);",
					"    if (!value || value.trim() === '') {",
					"        missingVars.push(REQUIRED_VARS[i]);",
					"    }",
					"}",
					"",
					"if (missingVars.length > 0) {",
					"    console.error('╔════════════════════════════════════════════════════════════════════════╗');",
					"    console.error('║  配置錯誤：缺少必要的 Collection Variables                          ║');",
					"    console.error('╚════════════════════════════════════════════════════════════════════════╝');",
					"    for (var j = 0; j < missingVars.length; j++) {",
					"        console.error('  ' + missingVars[j].key + ' - ' + missingVars[j].desc);",
					"    }",
					"    throw new Error('缺少 ' + missingVars.length + ' 個必要變數');",
					"}",
					"",
					"// ┌────────────────────────────────────────────────────────────────────────┐",
					"// │ 2. 讀取配置                                                            │",
					"// └────────────────────────────────────────────────────────────────────────┘",
					"",
					"var CONFIG = {",
					"    ldap: {",
					"        user: pm.collectionVariables.get('HTG_LDAP_USER'),",
					"        password: pm.collectionVariables.get('HTG_LDAP_PASSWORD')",
					"    },",
					"    appId: pm.collectionVariables.get('HTG_APP_ID'),",
					"    sit: {",
					"        endpoint: pm.collectionVariables.get('HTG_SIT_ENDPOINT'),",
					"        racfId: pm.collectionVariables.get('HTG_SIT_RACF_ID'),",
					"        racfPassword: pm.collectionVariables.get('HTG_SIT_RACF_PASSWORD'),",
					"        branchNo: pm.collectionVariables.get('HTG_SIT_BRANCH_NO')",
					"    },",
					"    uat: {",
					"        endpoint: pm.collectionVariables.get('HTG_UAT_ENDPOINT'),",
					"        racfId: pm.collectionVariables.get('HTG_UAT_RACF_ID'),",
					"        racfPassword: pm.collectionVariables.get('HTG_UAT_RACF_PASSWORD'),",
					"        branchNo: pm.collectionVariables.get('HTG_UAT_BRANCH_NO')",
					"    },",
					"    token: {",
					"        endpoint: pm.collectionVariables.get('TOKEN_ENDPOINT'),",
					"        expiryHours: parseInt(pm.collectionVariables.get('TOKEN_EXPIRY_HOURS'))",
					"    },",
					"    session: {",
					"        expiryHours: parseInt(pm.collectionVariables.get('SESSION_EXPIRY_HOURS'))",
					"    }",
					"};",
					"",
					"console.log('[Config] 所有變數已載入');",
					"",
					"// ┌────────────────────────────────────────────────────────────────────────┐",
					"// │ 3. 工具函數                                                            │",
					"// └────────────────────────────────────────────────────────────────────────┘",
					"",
					"function generateTraceId() {",
					"    var result = '';",
					"    for (var i = 0; i < 16; i++) {",
					"        result += (Math.floor(Math.random() * 256) & 0xff).toString(16).padStart(2, '0');",
					"    }",
					"    return result;",
					"}",
					"",
					"function generateSpanId() {",
					"    var result = '';",
					"    for (var i = 0; i < 8; i++) {",
					"        result += (Math.floor(Math.random() * 256) & 0xff).toString(16).padStart(2, '0');",
					"    }",
					"    return result;",
					"}",
					"",
					"function generateTimestamp() {",
					"    var now = new Date();",
					"    var offset = -now.getTimezoneOffset();",
					"    var sign = offset >= 0 ? '+' : '-';",
					"    var h = String(Math.floor(Math.abs(offset) / 60)).padStart(2, '0');",
					"    var m = String(Math.abs(offset) % 60).padStart(2, '0');",
					"    return now.getFullYear() + '-' +",
					"        String(now.getMonth() + 1).padStart(2, '0') + '-' +",
					"        String(now.getDate()).padStart(2, '0') + 'T' +",
					"        String(now.getHours()).padStart(2, '0') + ':' +",
					"        String(now.getMinutes()).padStart(2, '0') + ':' +",
					"        String(now.getSeconds()).padStart(2, '0') + '.' +",
					"        String(now.getMilliseconds()).padStart(3, '0') + sign + h + ':' + m;",
					"}",
					"",
					"function isExpired(lastTime, expiryHours) {",
					"    return !lastTime || (Date.now() - lastTime) > (expiryHours * 60 * 60 * 1000);",
					"}",
					"",
					"function buildHtgLoginXml(env) {",
					"    var cfg = CONFIG[env];",
					"    return '<?xml version=\"1.0\" encoding=\"UTF-8\"?>' +",
					"        '<hostgateway>' +",
					"        '<header><action type=\"P8EstablishSession\"/></header>' +",
					"        '<body>' +",
					"        '<data id=\"userId\" value=\"' + CONFIG.ldap.user + '\"/>' +",
					"        '<data id=\"passWord\" value=\"' + CONFIG.ldap.password + '\"/>' +",
					"        '<data id=\"branchNo\" value=\"' + cfg.branchNo + '\"/>' +",
					"        '<data id=\"racfId\" value=\"' + cfg.racfId + '\"/>' +",
					"        '<data id=\"racfPassWord\" value=\"' + cfg.racfPassword + '\"/>' +",
					"        '<data id=\"signOnLU0\" value=\"no0\"/>' +",
					"        '<data id=\"applicationId\" value=\"' + CONFIG.appId + '\"/>' +",
					"        '</body>' +",
					"        '</hostgateway>';",
					"}",
					"",
					"// ========== v7: 通用 ARPT 提取函數 (完整 debug 版) ==========",
					"function extractArptFromHeaders(headers, label) {",
					"    var arptValue = null;",
					"    ",
					"    if (!headers) {",
					"        console.log('[' + label + '] headers 為空');",
					"        return null;",
					"    }",
					"    ",
					"    // 方式 1: headers.all()",
					"    if (typeof headers.all === 'function') {",
					"        var allHeaders = headers.all();",
					"        console.log('[' + label + '] Response 共有 ' + allHeaders.length + ' 個 headers');",
					"        for (var i = 0; i < allHeaders.length; i++) {",
					"            var h = allHeaders[i];",
					"            var hKey = (h.key || h.name || '').toLowerCase();",
					"            var hVal = h.value || '';",
					"            // 顯示所有 Set-Cookie headers",
					"            if (hKey === 'set-cookie') {",
					"                console.log('[' + label + '] Set-Cookie: ' + hVal.substring(0, 100));",
					"            }",
					"            if (hKey === 'set-cookie' && hVal.indexOf('ARPT=') !== -1) {",
					"                var m = hVal.match(/ARPT=([^;]+)/);",
					"                if (m && m[1]) {",
					"                    arptValue = m[1];",
					"                    console.log('[' + label + '] 從 headers.all() 找到 ARPT: ' + arptValue);",
					"                }",
					"            }",
					"        }",
					"    }",
					"    ",
					"    // 方式 2: headers.members",
					"    if (!arptValue && headers.members && Array.isArray(headers.members)) {",
					"        console.log('[' + label + '] headers.members 有 ' + headers.members.length + ' 個');",
					"        for (var j = 0; j < headers.members.length; j++) {",
					"            var m2 = headers.members[j];",
					"            var mKey = (m2.key || m2.name || '').toLowerCase();",
					"            var mVal = m2.value || '';",
					"            if (mKey === 'set-cookie') {",
					"                console.log('[' + label + '] Set-Cookie (members): ' + mVal.substring(0, 100));",
					"            }",
					"            if (mKey === 'set-cookie' && mVal.indexOf('ARPT=') !== -1) {",
					"                var match = mVal.match(/ARPT=([^;]+)/);",
					"                if (match && match[1]) {",
					"                    arptValue = match[1];",
					"                    console.log('[' + label + '] 從 headers.members 找到 ARPT: ' + arptValue);",
					"                }",
					"            }",
					"        }",
					"    }",
					"    ",
					"    // 方式 3: headers.get('Set-Cookie') - 只能取第一個",
					"    if (!arptValue && typeof headers.get === 'function') {",
					"        var setCookie = headers.get('Set-Cookie');",
					"        if (setCookie) {",
					"            console.log('[' + label + '] headers.get Set-Cookie: ' + setCookie.substring(0, 100));",
					"            if (setCookie.indexOf('ARPT=') !== -1) {",
					"                var m3 = setCookie.match(/ARPT=([^;]+)/);",
					"                if (m3 && m3[1]) {",
					"                    arptValue = m3[1];",
					"                    console.log('[' + label + '] 從 headers.get() 找到 ARPT: ' + arptValue);",
					"                }",
					"            }",
					"        }",
					"    }",
					"    ",
					"    return arptValue;",
					"}",
					"",
					"// ========== v8: handleHtgResponse (Headers + Cookie Jar 雙重檢查) ==========",
					"function handleHtgResponse(res, env) {",
					"    var body = res.text();",
					"    var prefix = env === 'uat' ? 'uat' : 'sit';",
					"    var label = env.toUpperCase();",
					"    var htgDomain = env === 'uat' ? '192.168.38.139' : '192.168.38.136';",
					"    var htgUrl = 'http://' + htgDomain + '/WS_HG/HgXmlRequestHandler';",
					"    ",
					"    console.log('[' + label + '] ========== HTG Response ==========');",
					"    ",
					"    // 解析 sessionId",
					"    var sessionMatch = body.match(/<data id=\"sessionId\" value=\"([^\"]+)\"\\/>/);",
					"    if (sessionMatch && sessionMatch[1]) {",
					"        pm.globals.set(prefix + '-htg-session-id', sessionMatch[1]);",
					"        pm.globals.set('lastSessionTime', Date.now());",
					"        console.log('[' + label + '] Session: ' + sessionMatch[1]);",
					"    } else {",
					"        console.log('[' + label + '] Session 解析失敗');",
					"        console.log('[' + label + '] Response: ' + body.substring(0, 300));",
					"    }",
					"    ",
					"    // 方式 1: 從 Response Headers 提取 ARPT",
					"    console.log('[' + label + '] 檢查 Response Headers...');",
					"    var arptValue = extractArptFromHeaders(res.headers, label);",
					"    ",
					"    if (arptValue) {",
					"        pm.globals.set(prefix + '-htg-arpt', 'ARPT=' + arptValue);",
					"        console.log('[' + label + '] ARPT 已從 Headers 儲存: ARPT=' + arptValue);",
					"    } else {",
					"        // 方式 2: 從 Cookie Jar 讀取 (pm.sendRequest 可能自動存了)",
					"        console.log('[' + label + '] Headers 沒有 ARPT，嘗試從 Cookie Jar 讀取...');",
					"        try {",
					"            var cookieJar = pm.cookies.jar();",
					"            cookieJar.getAll(htgUrl, function(err, cookies) {",
					"                if (err) {",
					"                    console.log('[' + label + '] Cookie Jar 錯誤:', err);",
					"                    return;",
					"                }",
					"                if (cookies && cookies.length > 0) {",
					"                    console.log('[' + label + '] Cookie Jar 有 ' + cookies.length + ' 個 cookies');",
					"                    for (var i = 0; i < cookies.length; i++) {",
					"                        var c = cookies[i];",
					"                        var cName = (c.name || c.key || '').toUpperCase();",
					"                        var cValue = c.value || '';",
					"                        console.log('[' + label + '] Cookie: ' + cName + '=' + cValue.substring(0, 30));",
					"                        if (cName === 'ARPT' && cValue) {",
					"                            pm.globals.set(prefix + '-htg-arpt', 'ARPT=' + cValue);",
					"                            console.log('[' + label + '] ARPT 已從 Cookie Jar 儲存: ARPT=' + cValue);",
					"                        }",
					"                    }",
					"                } else {",
					"                    console.log('[' + label + '] Cookie Jar 是空的');",
					"                    // 檢查是否已有 ARPT",
					"                    var existingArpt = pm.globals.get(prefix + '-htg-arpt');",
					"                    if (existingArpt) {",
					"                        console.log('[' + label + '] ℹ使用現有 ARPT: ' + existingArpt);",
					"                    } else {",
					"                        console.log('[' + label + '] 未找到 ARPT');",
					"                        console.log('[' + label + '] 請手動執行一次「HTG-登入-' + label + '」或「取得 ARPT」請求');",
					"                    }",
					"                }",
					"            });",
					"        } catch (e) {",
					"            console.log('[' + label + '] Cookie Jar 存取失敗:', e);",
					"        }",
					"    }",
					"    ",
					"    console.log('[' + label + '] ====================================');",
					"}",
					"",
					"// ┌────────────────────────────────────────────────────────────────────────┐",
					"// │ 4. 自動產生 Traceparent & Timestamp                                    │",
					"// └────────────────────────────────────────────────────────────────────────┘",
					"",
					"pm.globals.set('traceparent', '00-' + generateTraceId() + '-' + generateSpanId() + '-01');",
					"pm.globals.set('x-timestamp', generateTimestamp());",
					"",
					"// ┌────────────────────────────────────────────────────────────────────────┐",
					"// │ 5. 自動取得 JWT Token (v7: 同時提取 ARPT)                               │",
					"// └────────────────────────────────────────────────────────────────────────┘",
					"",
					"(function() {",
					"    if (isExpired(pm.globals.get('lastTokenTime'), CONFIG.token.expiryHours)) {",
					"        console.log('[Token] ⏳ 過期或不存在，正在取得...');",
					"        pm.sendRequest(CONFIG.token.endpoint, function(err, res) {",
					"            if (err) { console.log('[Token] 錯誤:', err); return; }",
					"            try {",
					"                pm.globals.set('x-authorization-ap', 'Bearer ' + res.json().access_token);",
					"                pm.globals.set('lastTokenTime', Date.now());",
					"                console.log('[Token] 已更新');",
					"                ",
					"                // ========== v7: 從 Token Response 提取 ARPT (使用通用函數) ==========",
					"                console.log('[Token] ========== Token Response ==========');",
					"                console.log('[Token] 檢查 Response Headers 是否有 ARPT...');",
					"                var tokenArpt = extractArptFromHeaders(res.headers, 'Token');",
					"                if (tokenArpt) {",
					"                    // Token endpoint 是通用的，同時存到 SIT 和 UAT",
					"                    pm.globals.set('sit-htg-arpt', 'ARPT=' + tokenArpt);",
					"                    pm.globals.set('uat-htg-arpt', 'ARPT=' + tokenArpt);",
					"                    console.log('[Token] ARPT 已儲存到 SIT 和 UAT: ARPT=' + tokenArpt);",
					"                } else {",
					"                    console.log('[Token] ℹToken Response 沒有 ARPT (這是正常的，ARPT 可能來自 HTG)');",
					"                }",
					"                console.log('[Token] ====================================')",
					"            } catch (e) { console.log('[Token] 解析失敗:', e); }",
					"        });",
					"    } else {",
					"        console.log('[Token] 有效');",
					"    }",
					"})();",
					"",
					"// ┌────────────────────────────────────────────────────────────────────────┐",
					"// │ 6. 自動取得 HTG Session (SIT + UAT)                                    │",
					"// └────────────────────────────────────────────────────────────────────────┘",
					"",
					"(function() {",
					"    if (isExpired(pm.globals.get('lastSessionTime'), CONFIG.session.expiryHours)) {",
					"        console.log('[Session] ⏳ 過期或不存在，正在取得...');",
					"        ",
					"        // 讀取現有 ARPT (如果有的話)",
					"        var sitArpt = pm.globals.get('sit-htg-arpt') || '';",
					"        var uatArpt = pm.globals.get('uat-htg-arpt') || '';",
					"        ",
					"        // SIT 登入",
					"        pm.sendRequest({",
					"            url: CONFIG.sit.endpoint,",
					"            method: 'POST',",
					"            header: {",
					"                'Content-Type': 'application/xml',",
					"                'Cookie': sitArpt",
					"            },",
					"            body: { mode: 'raw', raw: buildHtgLoginXml('sit') }",
					"        }, function(err, res) {",
					"            if (err) { console.log('[SIT] 錯誤:', err); return; }",
					"            handleHtgResponse(res, 'sit');",
					"        });",
					"        ",
					"        // UAT 登入",
					"        pm.sendRequest({",
					"            url: CONFIG.uat.endpoint,",
					"            method: 'POST',",
					"            header: {",
					"                'Content-Type': 'application/xml',",
					"                'Cookie': uatArpt",
					"            },",
					"            body: { mode: 'raw', raw: buildHtgLoginXml('uat') }",
					"        }, function(err, res) {",
					"            if (err) { console.log('[UAT] 錯誤:', err); return; }",
					"            handleHtgResponse(res, 'uat');",
					"        });",
					"    } else {",
					"        console.log('[Session] 有效');",
					"    }",
					"})();",
					"",
					"console.log('────────────────────────────────────────────────────────────────');"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
