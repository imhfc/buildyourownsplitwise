#!/bin/bash
# Git Pre-commit Hook：檢查簡體中文
# 安裝方式：
#   cp .claude/scripts/pre-commit-traditional-chinese .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

# 簡體中文特有字符清單（從 ADR-014）
# 注意：僅包含簡體特有字，不包含繁簡共用字
SIMPLIFIED_CHARS="设计认证获标识录记据库显实验响应户请参类处执创复杂结构统维态错误义业东两门马书长车风飞鱼鸟龙开关发现机过给当进让头将无话经电间见听学"

# 顏色定義
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "Pre-commit: 檢查簡體中文..."

# 取得 staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(java|md)$')

if [ -z "$STAGED_FILES" ]; then
    echo "沒有需要檢查的檔案"
    exit 0
fi

ERROR_FOUND=0

# 檢查每個 staged file
for file in $STAGED_FILES; do
    # 檢查 staged 內容（不是工作區內容）
    if git diff --cached "$file" | grep -q "^+.*[$SIMPLIFIED_CHARS]"; then
        echo -e "${RED}發現簡體中文: $file${NC}"
        echo "   變更內容："
        git diff --cached "$file" | grep "^+.*[$SIMPLIFIED_CHARS]" | head -3 | sed 's/^/   /'
        echo ""
        ERROR_FOUND=1
    fi
done

if [ $ERROR_FOUND -eq 1 ]; then
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}Commit 被拒絕：發現簡體中文${NC}"
    echo -e "${YELLOW}請依據 ADR-014 規範改用繁體中文後再提交${NC}"
    echo ""
    echo "常見簡繁對照："
    echo "  设 → 設, 计 → 計, 认 → 認, 证 → 證"
    echo "  获 → 獲, 标 → 標, 识 → 識, 录 → 錄"
    echo "  记 → 記, 据 → 據, 库 → 庫, 显 → 顯"
    echo "  实 → 實, 验 → 驗, 响 → 響, 应 → 應"
    echo ""
    echo "參考文檔："
    echo "  .ai-docs/knowledge/universal/adr/ADR-014-traditional-chinese-only.md"
    echo -e "${RED}========================================${NC}"
    exit 1
fi

echo "簡體中文檢查通過"
exit 0
